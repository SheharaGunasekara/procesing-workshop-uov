color leafColour, trunkColour;

void setup()
{
  size(800, 400);
  //noStroke();
  leafColour  = color(#065001);
  trunkColour = color(#480627);
}

void draw()
{
  background(157, 238, 247);  // Sky
  fill(156, 245, 170);        // Ground
  rect(0, height/2, width, height/2);

  for (float xPos = 50; xPos < width; xPos = xPos + 100)
  {
    drawTree(xPos, 150);
    
  }
   for (float xPos = 10; xPos < width; xPos = xPos + 100)
  {
    drawTree2(xPos, 220);
    
  }
   for (float xPos = 50; xPos < width; xPos = xPos + 100)
  {
    drawTree3(xPos, 270);
    
  }
}

void drawTree(float treeX, float treeY)
{
  fill(trunkColour);
  rect(treeX, treeY, 10, 50);
  fill(leafColour);
  ellipse(treeX + 10, treeY - 30, 50, 70);
}

void drawTree2(float treeX, float treeY)
{
  fill(trunkColour);
  rect(treeX, treeY, 15, 60);
  fill(leafColour);
  ellipse(treeX + 10, treeY - 30, 60, 80);
}
void drawTree3(float treeX, float treeY)
{
  fill(trunkColour);
  rect(treeX, treeY, 20, 70);
  fill(leafColour);
  ellipse(treeX + 10, treeY - 30, 80, 100);
}
