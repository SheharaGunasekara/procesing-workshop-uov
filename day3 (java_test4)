void setup() {
  size(400, 400);
  noStroke();
}

void draw() {
  background(255);

  int mouseCol = mouseX / 40;
  int mouseRow = mouseY / 40;

  for (int row = 0; row < 10; row++) {
    for (int col = 0; col < 10; col++) {
      

      if (row == mouseRow || col == mouseCol) {
        fill(50, 150, 255); 
      } else {
        fill(180, 50, 50, 100);
      }
      
      ellipse(20 + col * 40, 20 + row * 40, 30, 30);
    }
  }
}
