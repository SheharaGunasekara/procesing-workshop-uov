float x;
float y;


void setup(){
  size (500,400);
  x=100;
  y=100;

}

void draw(){
   background(255);
   fill(#00F4FF);
   rect(x,y,60,30);
   noStroke();


}

void keyPressed(){
 if (keyCode == LEFT){x=x-4;}
 if (keyCode == RIGHT) {x=x+4;}
 if (keyCode == UP) {y=y-4;}
 if (keyCode == DOWN) {y=y+4;}

}
