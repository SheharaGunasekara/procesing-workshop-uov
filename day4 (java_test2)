Ball ball1;

void setup(){
    size (500,400);
    ball1 = new Ball(50,60,50, color(random(255),random(255),random(255)));
}

void draw(){
  background(0);
  
  ball1.update();
  ball1.display();
}

class Ball{

  float x,y;
  float vx,vy;
  float radius;
  color col;
  
  Ball(float startX,float startY,float r,color col1) {
    x = startX;
    y = startY;
    radius = r;
    col = col1;
    vx = 2;
    vy = 2;
  }
    
  void update(){
    x = x + vx;
    y = y + vy;
  
   if(x - radius < 0 || x + radius > width){
     vx = -vx;
   }  
   
   if(y - radius < 0 || y + radius > height){
     vy = -vy;
   } 
  }

void display(){
    fill(col);
    ellipse(x,y,radius * 2,radius * 2);
}

}

  
  
